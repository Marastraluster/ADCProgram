line level    source

   1          #include <REG52.H>
   2          #include <INTRINS.H>
   3          
   4          //引脚定义
   5          sbit XPT2046_DIN=P3^4;
   6          sbit XPT2046_CS=P3^5;
   7          sbit XPT2046_DCLK=P3^6;
   8          sbit XPT2046_DOUT=P3^7;
   9          
  10          /**
  11            * @brief  XPT2046读取AD值
  12            * @param  Command 命令字，范围：头文件内定义的宏，结尾的数字表示转换的位数
  13            * @retval AD转换后的数字量，范围：8位为0~255，12位为0~4095
  14            */
  15          unsigned int XPT2046_ReadAD(unsigned char Command)
  16          {
  17   1          unsigned char i;
  18   1          unsigned int Data=0;
  19   1          XPT2046_DCLK=0;
  20   1          XPT2046_CS=0;
  21   1          for(i=0;i<8;i++)
  22   1          {
  23   2              XPT2046_DIN=Command&(0x80>>i);
  24   2              XPT2046_DCLK=1;
  25   2              XPT2046_DCLK=0;
  26   2          }
  27   1          for(i=0;i<16;i++)
  28   1          {
  29   2              XPT2046_DCLK=1;
  30   2              XPT2046_DCLK=0;
  31   2              if(XPT2046_DOUT){Data|=(0x8000>>i);}
  32   2          }
  33   1          XPT2046_CS=1;
  34   1          return Data>>8;
  35   1      }
