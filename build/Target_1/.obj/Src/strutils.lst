   1          /**
   2            * @brief  比较两个字符串是否相同
   3            * @param  s1 字符串1
   4            * @param  s2 字符串2
   5            * @retval 1=相同，0=不同
   6            */
   7          unsigned char Str_Compare(unsigned char *s1, unsigned char *s2)
   8          {
   9   1          while (*s1 && *s2)
  10   1          {
  11   2              if (*s1 != *s2) return 0;
  12   2              s1++;
  13   2              s2++;
  14   2          }
  15   1          return (*s1 == *s2);
  16   1      }
  17          
  18          /**
  19            * @brief  从字符串中解析十进制数字
  20            * @param  Str 指向数字起始位置的指针
  21            * @retval 解析出的数值
  22            */
  23          unsigned int Str_GetNumber(unsigned char *Str)
  24          {
  25   1          unsigned int Result = 0;
  26   1          while (*Str >= '0' && *Str <= '9')
  27   1          {
  28   2              Result = Result * 10 + (*Str - '0');
  29   2              Str++;
  30   2          }
  31   1          return Result;
  32   1      }
