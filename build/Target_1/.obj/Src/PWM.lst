  32            * @param  Freq 频率值(Hz)，范围100-5000
  33            * @retval 无
  34            */
  35          void PWM_SetFrequency(unsigned int Freq)
  36          {
  37   1          unsigned int HighCount;
  38   1          unsigned int LowCount;
  39   1          if (Freq < 100) Freq = 100;
