   7          /**
   8            * @brief  将unsigned char转为ASCII字符串写入缓冲区
   9            * @param  buf 目标缓冲区
  10            * @param  val 要转换的值(0-255)
  11            * @retval 写入的字符数
  12            */
  13          static unsigned char ByteToAscii(unsigned char *buf, unsigned char val)
  14          {
  15   1          unsigned char len = 0;
  16   1          if (val >= 100)
  17   1          {
  18   2              buf[len++] = '0' + val / 100;
  19   2              val %= 100;
  20   2              buf[len++] = '0' + val / 10;
  21   2              val %= 10;
  22   2              buf[len++] = '0' + val;
  23   2          }
  24   1          else if (val >= 10)
  25   1          {
  26   2              buf[len++] = '0' + val / 10;
  27   2              val %= 10;
  28   2              buf[len++] = '0' + val;
  29   2          }
  30   1          else
  31   1          {
  32   2              buf[len++] = '0' + val;
  33   2          }
  34   1          return len;
  35   1      }
